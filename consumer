<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>CBOXX — Join Loyalty</title>
<meta name="theme-color" content="#000000">
<link rel="icon" type="image/png" href="data:image/png;base64,">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700;900&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;}
body{font-family:'Inter',sans-serif;background:#111;min-height:100vh;display:flex;align-items:flex-start;justify-content:center;padding:2rem 1rem;}
.shell{width:100%;max-width:390px;background:#000;min-height:100vh;position:relative;overflow:hidden;}
@media(min-width:500px){body{align-items:center;background:#0a0a0a;}.shell{border-radius:40px;min-height:auto;box-shadow:0 30px 80px rgba(0,0,0,0.8),0 0 0 1px rgba(255,255,255,0.06);}}
.screen{display:none;flex-direction:column;width:100%;}
.screen.active{display:flex;animation:sIn 0.42s cubic-bezier(0.25,0.46,0.45,0.94) both;}
@keyframes sIn{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}
@keyframes fadeUp{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:translateY(0)}}
@keyframes tickPop{0%{opacity:0;transform:scale(0.3)}60%{transform:scale(1.15)}80%{transform:scale(0.95)}100%{opacity:1;transform:scale(1)}}
@keyframes cardFloat{0%,100%{transform:translateY(0)}50%{transform:translateY(-5px)}}
@keyframes nfcRing{0%{width:0;height:0;opacity:0.7}100%{width:32px;height:32px;opacity:0}}
:root{--red:#8B0015;--yellow:#C9963A;--green:#165C32;--off:#E8E4DF;--dim:rgba(255,255,255,0.38);--card:#0D1520;--border:rgba(255,255,255,0.08);}
.pad{padding:2rem 1.5rem;}
.gap{display:flex;flex-direction:column;gap:1.1rem;}
.eyebrow{font-size:0.6rem;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:rgba(255,255,255,0.28);}
.headline{font-family:'Barlow Condensed',sans-serif;font-size:2.8rem;font-weight:900;text-transform:uppercase;color:var(--off);line-height:1;}
.headline em{color:var(--red);font-style:normal;display:block;}
.sub{font-size:0.88rem;line-height:1.65;color:var(--dim);}
.divider{height:1px;background:rgba(255,255,255,0.07);}
.pill-red{display:inline-flex;align-items:center;gap:0.3rem;font-size:0.58rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;padding:0.2rem 0.55rem;border-radius:100px;background:rgba(139,0,21,0.2);border:1px solid rgba(139,0,21,0.35);color:#ff8c8c;}
.pill-amber{display:inline-flex;align-items:center;gap:0.3rem;font-size:0.58rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;padding:0.2rem 0.55rem;border-radius:100px;background:rgba(201,150,58,0.15);border:1px solid rgba(201,150,58,0.3);color:var(--yellow);}
.btn{width:100%;padding:1rem;border:none;border-radius:10px;font-family:'Inter',sans-serif;font-size:0.95rem;font-weight:700;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:0.5rem;transition:all 0.2s;}
.btn-red{background:var(--red);color:white;box-shadow:0 4px 20px rgba(139,0,21,0.35);}
.btn-red:active{background:#7A0012;transform:scale(0.97);}
.btn-red:disabled{opacity:0.4;cursor:default;transform:none;}
.btn-ghost{background:rgba(255,255,255,0.05);color:rgba(255,255,255,0.5);border:1px solid rgba(255,255,255,0.08);}
.btn-sub{text-align:center;font-size:0.62rem;color:rgba(255,255,255,0.2);margin-top:0.4rem;}
.back-btn{background:none;border:none;font-family:'Inter',sans-serif;font-size:0.75rem;color:rgba(255,255,255,0.3);cursor:pointer;padding:0;display:inline-flex;align-items:center;gap:0.3rem;}

/* Phone input */
.phone-wrap{position:relative;}
.phone-flag{position:absolute;left:1rem;top:50%;transform:translateY(-50%);font-size:1rem;pointer-events:none;display:flex;align-items:center;gap:0.4rem;}
.phone-flag span{font-size:0.78rem;color:rgba(255,255,255,0.4);font-weight:600;}
.phone-input{width:100%;padding:1rem 1rem 1rem 3.8rem;background:rgba(255,255,255,0.05);border:1.5px solid rgba(255,255,255,0.1);border-radius:10px;color:var(--off);font-family:'Inter',sans-serif;font-size:1.1rem;font-weight:600;letter-spacing:0.05em;outline:none;transition:border-color 0.2s;}
.phone-input:focus{border-color:var(--red);}
.phone-input.valid{border-color:#3ab86a;}
.phone-input.error{border-color:#ff6b6b;}
.input-hint{font-size:0.65rem;color:rgba(255,255,255,0.25);margin-top:0.4rem;}
.input-hint.err{color:#ff6b6b;}

/* Loyalty card */
.loyalty-card{background:linear-gradient(135deg,#0D1520,#111827);border:1px solid rgba(255,255,255,0.1);border-radius:16px;padding:1.25rem;animation:cardFloat 4s ease-in-out infinite;}
.lc-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:0.75rem;}
.lc-ml{font-size:0.52rem;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;color:rgba(255,255,255,0.25);margin-bottom:0.18rem;}
.lc-mn{font-family:'Barlow Condensed',sans-serif;font-size:1.05rem;font-weight:900;color:var(--off);text-transform:uppercase;}
.lc-stats{display:flex;gap:1.5rem;margin-bottom:0.85rem;}
.lc-sl{font-size:0.52rem;color:rgba(255,255,255,0.25);text-transform:uppercase;letter-spacing:0.1em;margin-bottom:0.1rem;}
.lc-sv{font-family:'Barlow Condensed',sans-serif;font-size:1.3rem;font-weight:900;color:var(--yellow);}
.nfc-ring{position:absolute;border-radius:50%;border:1.5px solid rgba(139,0,21,0.5);animation:nfcRing 2.8s ease infinite;}
.nfc-ring:nth-child(2){animation-delay:0.7s}
.nfc-sm{position:relative;width:28px;height:28px;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.nfc-core{width:18px;height:18px;background:var(--red);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:0.5rem;z-index:2;}
.live-strip{display:flex;align-items:center;justify-content:space-between;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.07);border-radius:10px;padding:0.7rem 1.1rem;}
.ls-num{font-family:'Barlow Condensed',sans-serif;font-size:1.2rem;font-weight:900;color:var(--off);line-height:1;}
.ls-label{font-size:0.55rem;color:rgba(255,255,255,0.26);margin-top:0.12rem;}
.ls-div{width:1px;height:24px;background:rgba(255,255,255,0.08);}
.perks{display:grid;grid-template-columns:repeat(3,1fr);gap:0.55rem;}
.perk{background:rgba(255,255,255,0.04);border:1px solid var(--border);border-radius:8px;padding:0.7rem 0.4rem;text-align:center;}
.perk-icon{font-size:1.1rem;display:block;margin-bottom:0.2rem;}
.perk-label{font-size:0.58rem;color:rgba(255,255,255,0.38);line-height:1.3;}

/* Consent */
.consent-item{display:flex;align-items:flex-start;gap:0.8rem;padding:0.85rem;background:rgba(255,255,255,0.03);border:1.5px solid rgba(255,255,255,0.07);border-radius:10px;cursor:pointer;transition:border-color 0.2s,background 0.2s;}
.consent-item.selected{border-color:var(--red);background:rgba(139,0,21,0.06);}
.ccheck{width:20px;height:20px;border-radius:50%;border:2px solid rgba(255,255,255,0.18);display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px;transition:all 0.2s;}
.consent-item.selected .ccheck{background:var(--red);border-color:var(--red);}
.ccheck-dot{width:8px;height:8px;border-radius:50%;background:white;opacity:0;transition:opacity 0.2s;}
.consent-item.selected .ccheck-dot{opacity:1;}
.ctitle{font-size:0.82rem;font-weight:600;color:var(--off);margin-bottom:0.18rem;}
.cdesc{font-size:0.68rem;color:rgba(255,255,255,0.32);line-height:1.45;}
.pdpa{background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.05);border-radius:8px;padding:0.85rem;display:flex;gap:0.55rem;font-size:0.63rem;color:rgba(255,255,255,0.22);line-height:1.55;}

/* Enrolled + member card */
.enrolled-tick{width:80px;height:80px;background:var(--green);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:2rem;box-shadow:0 0 40px rgba(22,92,50,0.4);animation:tickPop 0.55s cubic-bezier(0.175,0.885,0.32,1.275) both;}
.member-card{background:linear-gradient(135deg,#0D1520,#111827);border:1px solid rgba(255,255,255,0.1);border-radius:16px;padding:1.25rem;}
.mc-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:0.75rem;}
.mc-ml{font-size:0.52rem;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;color:rgba(255,255,255,0.25);margin-bottom:0.2rem;}
.mc-mn{font-family:'Barlow Condensed',sans-serif;font-size:1.05rem;font-weight:900;color:var(--off);text-transform:uppercase;}
.mc-pts{font-family:'Barlow Condensed',sans-serif;font-size:3rem;font-weight:900;color:var(--yellow);line-height:1;margin-bottom:0.15rem;}
.mc-pts-sub{font-size:0.68rem;color:rgba(255,255,255,0.28);margin-bottom:1rem;}
.prog-track{height:5px;background:rgba(255,255,255,0.07);border-radius:3px;overflow:hidden;}
.prog-fill{height:100%;background:linear-gradient(90deg,var(--red),var(--yellow));border-radius:3px;width:0;transition:width 1.2s cubic-bezier(0.4,0,0.2,1) 0.8s;box-shadow:0 0 6px rgba(201,150,58,0.3);}
.prog-row{display:flex;justify-content:space-between;margin-bottom:0.35rem;font-size:0.6rem;color:rgba(255,255,255,0.28);}
.rp-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:0.5rem;}
.rp{background:rgba(255,255,255,0.04);border:1px solid var(--border);border-radius:8px;padding:0.65rem 0.4rem;text-align:center;}
.rp-icon{font-size:1rem;display:block;margin-bottom:0.2rem;}
.rp-label{font-size:0.56rem;color:rgba(255,255,255,0.35);line-height:1.3;}

/* Bottom nav */
.bottom-nav{background:#000;border-top:1px solid rgba(255,255,255,0.06);display:flex;padding:0.75rem 0 1rem;}
.bn-item{flex:1;display:flex;flex-direction:column;align-items:center;gap:0.25rem;cursor:pointer;padding:0.25rem;}
.bn-icon{font-size:1.1rem;}
.bn-label{font-size:0.55rem;color:rgba(255,255,255,0.3);font-weight:500;transition:color 0.2s;}
.bn-item.active .bn-label{color:var(--red);}

/* Home page */
.pts-hero{background:linear-gradient(135deg,#0D1520,#111827);border:1px solid var(--border);border-radius:14px;padding:1.4rem;}
.pts-big{font-family:'Barlow Condensed',sans-serif;font-size:4rem;font-weight:900;color:var(--yellow);line-height:1;}
.tb{flex:1;padding:0.45rem 0.3rem;border-radius:6px;text-align:center;font-size:0.6rem;font-weight:700;}
.tb-bronze{background:rgba(139,0,21,0.15);border:1px solid rgba(139,0,21,0.3);color:#ff8c8c;}
.tb-silver{background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.12);color:rgba(255,255,255,0.5);}
.tb-gold{background:rgba(201,150,58,0.1);border:1px solid rgba(201,150,58,0.2);color:rgba(201,150,58,0.5);}
.visit-row{display:flex;align-items:center;gap:0.85rem;padding:0.65rem 0;border-bottom:1px solid rgba(255,255,255,0.04);}
.visit-row:last-child{border-bottom:none;}
.vi-icon{width:32px;height:32px;border-radius:8px;background:rgba(139,0,21,0.12);display:flex;align-items:center;justify-content:center;font-size:0.85rem;flex-shrink:0;}
.vi-title{font-size:0.8rem;font-weight:600;color:var(--off);}
.vi-date{font-size:0.62rem;color:rgba(255,255,255,0.28);margin-top:0.1rem;}
.vi-pts{font-family:'Barlow Condensed',sans-serif;font-size:1rem;font-weight:900;color:var(--yellow);}

/* Rewards */
.rl{display:flex;align-items:center;gap:0.85rem;padding:0.85rem;background:var(--card);border:1px solid var(--border);border-radius:10px;}
.rl-icon{font-size:1.4rem;flex-shrink:0;}
.rl-name{font-size:0.82rem;font-weight:600;color:var(--off);margin-bottom:0.15rem;}
.rl-desc{font-size:0.65rem;color:rgba(255,255,255,0.3);}
.rl-pts-num{font-family:'Barlow Condensed',sans-serif;font-size:1rem;font-weight:900;color:var(--yellow);}
.rl-pts-label{font-size:0.52rem;color:rgba(255,255,255,0.25);}

/* Returning */
.ret-pts-box{background:rgba(201,150,58,0.08);border:1px solid rgba(201,150,58,0.2);border-radius:12px;padding:1.1rem 1.25rem;display:flex;align-items:center;justify-content:space-between;}
.ret-big{font-family:'Barlow Condensed',sans-serif;font-size:2.8rem;font-weight:900;color:var(--yellow);line-height:1;}
.sk{flex:1;border-radius:6px;padding:0.6rem 0.4rem;text-align:center;}
.sk-num{font-family:'Barlow Condensed',sans-serif;font-size:1.4rem;font-weight:900;line-height:1;}
.sk-label{font-size:0.52rem;text-transform:uppercase;letter-spacing:0.08em;opacity:0.55;margin-top:0.1rem;}

/* Toggle */
.toggle{width:40px;height:22px;background:rgba(255,255,255,0.12);border-radius:11px;position:relative;cursor:pointer;transition:background 0.25s;flex-shrink:0;}
.toggle.on{background:var(--red);}
.toggle-knob{position:absolute;top:3px;left:3px;width:16px;height:16px;border-radius:50%;background:white;transition:transform 0.25s cubic-bezier(0.34,1.56,0.64,1);}
.toggle.on .toggle-knob{transform:translateX(18px);}
.s-row{display:flex;justify-content:space-between;align-items:center;padding:0.75rem 0;border-bottom:1px solid rgba(255,255,255,0.05);}
.s-row:last-child{border-bottom:none;}

.shop-card { background:var(--card); border:1px solid var(--border); border-radius:10px; padding:0.85rem; cursor:pointer; transition:border-color 0.2s; overflow:hidden; }
.shop-card:hover { border-color:rgba(139,0,21,0.35); }
.shop-detail { display:none; margin-top:0.85rem; padding-top:0.85rem; border-top:1px solid rgba(255,255,255,0.06); animation:fadeUp 0.25s ease both; }
.shop-detail.open { display:block; }
.tier-bar { display:flex; align-items:center; gap:0.35rem; margin-bottom:0.85rem; }
.tier-seg { flex:1; text-align:center; padding:0.5rem 0.3rem; border-radius:6px; font-size:0.6rem; font-weight:700; line-height:1.3; }
.tier-sub { font-size:0.5rem; font-weight:400; opacity:0.7; margin-top:0.15rem; }
.active-tier { background:rgba(139,0,21,0.1); border:1px solid rgba(139,0,21,0.2); color:#ff8c8c; }
.current-tier { background:rgba(201,150,58,0.2); border:1px solid rgba(201,150,58,0.4); color:var(--yellow); }
.locked-tier { background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.06); color:rgba(255,255,255,0.3); }
.tier-arrow { font-size:0.6rem; color:rgba(255,255,255,0.2); flex-shrink:0; }
.shop-rewards { display:flex; flex-direction:column; gap:0.5rem; }
.sr-title { font-size:0.6rem; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; color:rgba(255,255,255,0.25); margin-bottom:0.35rem; }
.sr-row { display:flex; align-items:center; gap:0.65rem; padding:0.6rem 0.75rem; border-radius:8px; }
.sr-row.unlocked { background:rgba(22,92,50,0.1); border:1px solid rgba(22,92,50,0.2); }
.sr-row.locked { background:rgba(255,255,255,0.03); border:1px solid rgba(255,255,255,0.06); opacity:0.65; }
.sr-icon { font-size:1rem; flex-shrink:0; }
.sr-info { flex:1; }
.sr-name { font-size:0.78rem; font-weight:600; color:var(--off); }
.sr-desc { font-size:0.62rem; color:rgba(255,255,255,0.3); margin-top:0.1rem; }
.sr-status { font-size:0.6rem; font-weight:700; padding:0.2rem 0.5rem; border-radius:100px; white-space:nowrap; }
.unlocked-badge { background:rgba(22,92,50,0.2); border:1px solid rgba(22,92,50,0.35); color:#3ab86a; }
.locked-badge { background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.08); color:rgba(255,255,255,0.35); }


/* Post-tap survey */
.star-row { display:flex; gap:0.75rem; justify-content:center; margin:1.25rem 0; }
.star-btn { font-size:2.2rem; cursor:pointer; transition:transform 0.2s cubic-bezier(0.34,1.56,0.64,1); opacity:0.35; border:none; background:none; padding:0.25rem; }
.star-btn.lit { opacity:1; transform:scale(1.15); }
.star-btn:active { transform:scale(0.9); }
.survey-opts { display:grid; grid-template-columns:1fr 1fr; gap:0.55rem; margin-bottom:0.5rem; }
.survey-opt { padding:0.75rem 0.85rem; background:rgba(255,255,255,0.04); border:1.5px solid rgba(255,255,255,0.07); border-radius:10px; font-size:0.78rem; font-weight:600; color:rgba(255,255,255,0.55); cursor:pointer; text-align:center; transition:all 0.18s; font-family:'Inter',sans-serif; }
.survey-opt:active,.survey-opt.picked { background:rgba(139,0,21,0.1); border-color:rgba(139,0,21,0.4); color:var(--off); }
.survey-opt.full-width { grid-column:1/-1; }
.survey-msg { width:100%; padding:0.85rem 1rem; background:rgba(255,255,255,0.04); border:1.5px solid rgba(255,255,255,0.08); border-radius:10px; color:var(--off); font-family:'Inter',sans-serif; font-size:0.88rem; outline:none; resize:none; transition:border-color 0.2s; }
.survey-msg:focus { border-color:var(--red); }
.survey-msg::placeholder { color:rgba(255,255,255,0.2); }
.survey-step { display:none; animation:fadeUp 0.35s ease both; }
.survey-step.active { display:block; }
.survey-progress { display:flex; gap:4px; margin-bottom:1.5rem; }
.sp-dot { flex:1; height:3px; border-radius:2px; background:rgba(255,255,255,0.1); transition:background 0.3s; }
.sp-dot.done { background:var(--red); }
.survey-thanks { display:flex; flex-direction:column; align-items:center; gap:0.85rem; text-align:center; animation:fadeUp 0.5s ease both; }
.survey-thanks-icon { width:64px; height:64px; background:var(--green); border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:1.8rem; animation:tickPop 0.55s cubic-bezier(0.175,0.885,0.32,1.275) both; box-shadow:0 0 30px rgba(22,92,50,0.3); }


.dtab { padding:0.4rem 1rem; border-radius:100px; border:1px solid rgba(255,255,255,0.12); color:rgba(255,255,255,0.4); font-size:0.75rem; font-weight:600; cursor:pointer; background:transparent; font-family:'Inter',sans-serif; transition:all 0.2s; white-space:nowrap; flex-shrink:0; }
.dtab.active { background:var(--red); border-color:var(--red); color:white; }
.district-panel { display:none; }
.district-panel.active { display:flex; flex-direction:column; gap:0.65rem; }
.mall-group { background:var(--card); border:1px solid var(--border); border-radius:12px; overflow:hidden; cursor:pointer; transition:border-color 0.2s; }
.mall-group:hover { border-color:rgba(139,0,21,0.3); }
.mall-group-header { display:flex; align-items:center; justify-content:space-between; padding:0.9rem 1rem; }
.mall-shops { display:none; padding:0 0.75rem 0.75rem; display:flex; flex-direction:column; gap:0.5rem; }
.mall-shops.open { display:flex; }


.area-group { background:var(--card); border:1px solid var(--border); border-radius:12px; overflow:hidden; }
.area-header { display:flex;align-items:center;justify-content:space-between;padding:1rem 1.1rem;cursor:pointer;transition:background 0.15s; }
.area-header:hover { background:rgba(255,255,255,0.04); }
.area-content { display:none;padding:0 0.75rem 0.75rem;display:flex;flex-direction:column;gap:0.5rem; }
.area-content.open { display:flex; }
.district-group { background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.06);border-radius:8px;overflow:hidden; }
.district-header { display:flex;align-items:center;justify-content:space-between;padding:0.7rem 0.85rem;cursor:pointer;transition:background 0.15s; }
.district-header:hover { background:rgba(255,255,255,0.04); }
.district-content { display:none;padding:0 0.65rem 0.65rem;display:flex;flex-direction:column;gap:0.45rem; }
.district-content.open { display:flex; }
.mall-item { background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.06);border-radius:8px;overflow:hidden;cursor:pointer;transition:border-color 0.2s; }
.mall-item:hover { border-color:rgba(139,0,21,0.25); }
.mall-item-header { display:flex;align-items:center;justify-content:space-between;padding:0.7rem 0.85rem; }
.mall-shops { display:none;padding:0 0.65rem 0.65rem;display:flex;flex-direction:column;gap:0.4rem; }
.mall-shops.open { display:flex; }
.shop-row { background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.06);border-radius:7px;padding:0.65rem 0.75rem;cursor:pointer;transition:border-color 0.2s; }
.shop-row:hover { border-color:rgba(139,0,21,0.25); }

</style>
</head>
<body>
<div class="shell">

<!-- S1: WELCOME -->
<div class="screen active" id="s1">
  <div class="pad gap" style="background:#000;gap:1.25rem">
    <div style="background:#000;display:inline-block;border-radius:6px;padding:2px 0"><img src="data:image/png;base64," alt="CBOXX" style="height:36px;width:auto;display:block"></div>
    <div style="display:inline-flex;align-items:center;gap:0.4rem;font-size:0.62rem;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:rgba(255,255,255,0.55);border:1px solid rgba(255,255,255,0.15);padding:0.3rem 0.85rem;border-radius:100px;width:fit-content;background:rgba(255,255,255,0.04);">
      <span style="width:5px;height:5px;border-radius:50%;background:#3ab86a;display:inline-block;flex-shrink:0"></span>
      <span id="mallTag">Tampines Mall</span>
    </div>
    <div>
      <div class="headline" style="font-size:clamp(2.8rem,10vw,3.5rem)">Welcome<br>to <em id="mName">Demo Store.</em></div>
      <p class="sub" style="margin-top:0.6rem;font-size:0.92rem;color:rgba(255,255,255,0.48)">Earn points every visit. Unlock exclusive rewards. No app download — ever.</p>
    </div>
    <div class="loyalty-card">
      <div class="lc-top">
        <div><div class="lc-ml">Loyalty Member</div><div class="lc-mn" id="lpName">Demo Store</div></div>
        <span class="pill-red">🥉 Bronze</span>
      </div>
      <div class="divider" style="margin-bottom:0.75rem"></div>
      <div class="lc-stats">
        <div><div class="lc-sl">Points</div><div class="lc-sv" id="lpPts">0</div></div>
        <div><div class="lc-sl">Visits</div><div class="lc-sv">0</div></div>
        <div><div class="lc-sl">Rewards</div><div class="lc-sv">3</div></div>
      </div>
      <div style="display:flex;align-items:center;gap:0.6rem">
        <div class="nfc-sm"><div class="nfc-ring"></div><div class="nfc-ring"></div><div class="nfc-core">📲</div></div>
        <span style="font-size:0.65rem;color:rgba(255,255,255,0.28)">Enter your number to activate</span>
      </div>
    </div>
    <div class="live-strip">
      <div><div class="ls-num" id="lsM">0</div><div class="ls-label">members today</div></div>
      <div class="ls-div"></div>
      <div><div class="ls-num" id="lsT">0</div><div class="ls-label">taps this week</div></div>
      <div class="ls-div"></div>
      <div><div class="ls-num">Free</div><div class="ls-label">no app needed</div></div>
    </div>
    <div class="perks">
      <div class="perk"><span class="perk-icon">⭐</span><span class="perk-label">Earn points every visit</span></div>
      <div class="perk"><span class="perk-icon">🎁</span><span class="perk-label">Exclusive rewards</span></div>
      <div class="perk"><span class="perk-icon">📲</span><span class="perk-label">No app download</span></div>
    </div>
    <div>
      <button class="btn btn-red" onclick="goTo('s2');vibe(30)" style="font-size:1rem;padding:1.1rem;letter-spacing:0.02em">Join Loyalty Programme →</button>
      <div class="btn-sub" style="font-size:0.65rem;margin-top:0.5rem;color:rgba(255,255,255,0.25)">Takes 10 seconds · PDPA compliant · Always free</div>
    </div>
    <div style="text-align:center">
      <button onclick="goTo('s_ret_input');vibe(20)" style="background:none;border:none;font-family:'Inter',sans-serif;font-size:0.65rem;color:rgba(255,255,255,0.2);cursor:pointer;text-decoration:underline">Already a member? Tap to check in →</button>
    </div>
  </div>
</div>

<!-- S2: PHONE NUMBER -->
<div class="screen" id="s2">
  <div class="pad gap" style="background:#060C12;min-height:100vh">
    <button class="back-btn" onclick="goTo('s1')">← Back</button>
    <div>
      <div class="eyebrow" style="margin-bottom:0.5rem">Step 1 of 2</div>
      <div class="headline" style="font-size:2.2rem">Your phone<br>number.</div>
      <p class="sub" style="margin-top:0.5rem">We use this to identify you on every visit. No password. No account needed.</p>
    </div>
    <div>
      <div class="phone-wrap">
        <div class="phone-flag">🇸🇬 <span>+65</span></div>
        <input type="tel" class="phone-input" id="phoneInput" placeholder="8123 4567" maxlength="8" oninput="onPhone(this)" onkeydown="if(event.key==='Enter'&&!document.getElementById('phoneBtn').disabled)submitPhone()">
      </div>
      <div class="input-hint" id="phoneHint">Enter your 8-digit Singapore mobile number</div>
    </div>
    <div style="background:rgba(29,78,216,0.08);border:1px solid rgba(29,78,216,0.2);border-radius:10px;padding:1rem">
      <div style="font-size:0.65rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:#60a5fa;margin-bottom:0.5rem">How we use your number</div>
      <div style="display:flex;flex-direction:column;gap:0.5rem">
        <div style="display:flex;gap:0.6rem"><span style="color:#3ab86a;font-size:0.8rem;flex-shrink:0">✓</span><span style="font-size:0.75rem;color:rgba(255,255,255,0.45);line-height:1.5">Identifies you as a returning member next visit</span></div>
        <div style="display:flex;gap:0.6rem"><span style="color:#3ab86a;font-size:0.8rem;flex-shrink:0">✓</span><span style="font-size:0.75rem;color:rgba(255,255,255,0.45);line-height:1.5">Links your points across CBOXX merchants in this mall</span></div>
        <div style="display:flex;gap:0.6rem"><span style="color:#3ab86a;font-size:0.8rem;flex-shrink:0">✓</span><span style="font-size:0.75rem;color:rgba(255,255,255,0.45);line-height:1.5">Never shared · PDPA protected</span></div>
        <div style="display:flex;gap:0.6rem"><span style="color:#ff8c8c;font-size:0.8rem;flex-shrink:0">✗</span><span style="font-size:0.75rem;color:rgba(255,255,255,0.45);line-height:1.5">No spam calls or messages without consent</span></div>
      </div>
    </div>
    <button class="btn btn-red" id="phoneBtn" onclick="submitPhone()" disabled>Continue →</button>
    <div class="pdpa"><span>🔒</span><span>Protected under Singapore's PDPA · CBOXX Pte. Ltd. (UEN: 202613969N)</span></div>
  </div>
</div>

<!-- S2B: OTP -->
<div class="screen" id="s2b">
  <div class="pad gap" style="background:#060C12;min-height:100vh">
    <button class="back-btn" onclick="goTo('s2')">← Back</button>
    <div>
      <div class="eyebrow" style="margin-bottom:0.5rem">Step 1B · Verify</div>
      <div class="headline" style="font-size:2.2rem">Check your<br>SMS.</div>
      <p class="sub" style="margin-top:0.5rem">Sent a 6-digit code to <strong id="phoneDisplay" style="color:var(--off)">+65 ···· ····</strong></p>
    </div>
    <div>
      <input type="text" class="phone-input" id="otpInput" maxlength="6" placeholder="· · · · · ·" style="text-align:center;letter-spacing:0.3em;font-size:1.5rem;padding-left:1rem" oninput="onOtp(this)">
      <div class="input-hint" id="otpHint" style="text-align:center">Enter the 6-digit code</div>
    </div>
    <div style="background:rgba(201,150,58,0.06);border:1px solid rgba(201,150,58,0.15);border-radius:8px;padding:0.85rem;text-align:center">
      <div style="font-size:0.65rem;font-weight:700;color:var(--yellow);margin-bottom:0.2rem">DEMO MODE</div>
      <div style="font-size:0.72rem;color:rgba(255,255,255,0.4)">Enter <strong style="color:var(--off)">123456</strong> → new member &nbsp;|&nbsp; <strong style="color:var(--off)">654321</strong> → returning member</div>
    </div>
    <button class="btn btn-red" id="otpBtn" onclick="submitOtp()" disabled>Verify →</button>
    <div style="text-align:center"><button onclick="resend()" style="background:none;border:none;font-family:'Inter',sans-serif;font-size:0.78rem;color:var(--red);cursor:pointer;font-weight:600">Resend SMS →</button></div>
  </div>
</div>

<!-- S2C: OPTIONAL PROFILE -->
<div class="screen" id="s2c">
  <div class="pad gap" style="background:#060C12;min-height:100vh">
    <button class="back-btn" onclick="goTo('s2b')">← Back</button>
    <div>
      <div class="eyebrow" style="margin-bottom:0.5rem">Optional · Build your profile</div>
      <div class="headline" style="font-size:2.2rem">A little more<br>about you.</div>
      <p class="sub" style="margin-top:0.5rem">All optional. Skip anytime. Helps us personalise your rewards.</p>
    </div>

    <div style="display:flex;flex-direction:column;gap:0.75rem">
      <!-- Name -->
      <div>
        <div style="font-size:0.68rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:rgba(255,255,255,0.3);margin-bottom:0.4rem">Your name</div>
        <input type="text" id="profileName" class="phone-input" placeholder="e.g. Sarah" style="padding:0.9rem 1rem;font-size:0.95rem;letter-spacing:0;font-weight:500">
      </div>
      <!-- Email -->
      <div>
        <div style="font-size:0.68rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:rgba(255,255,255,0.3);margin-bottom:0.4rem">Email address</div>
        <input type="email" id="profileEmail" class="phone-input" placeholder="e.g. sarah@email.com" style="padding:0.9rem 1rem;font-size:0.95rem;letter-spacing:0;font-weight:500">
        <div class="input-hint">For campaign offers and reward notifications</div>
      </div>
      <!-- Birthday month -->
      <div>
        <div style="font-size:0.68rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:rgba(255,255,255,0.3);margin-bottom:0.4rem">Birthday month</div>
        <select id="profileBday" style="width:100%;padding:0.9rem 1rem;background:rgba(255,255,255,0.05);border:1.5px solid rgba(255,255,255,0.1);border-radius:10px;color:rgba(255,255,255,0.6);font-family:Inter,sans-serif;font-size:0.95rem;outline:none;appearance:none;-webkit-appearance:none">
          <option value="">Select month</option>
          <option>January</option><option>February</option><option>March</option>
          <option>April</option><option>May</option><option>June</option>
          <option>July</option><option>August</option><option>September</option>
          <option>October</option><option>November</option><option>December</option>
        </select>
        <div class="input-hint">Unlocks a birthday reward every year</div>
      </div>
    </div>

    <!-- Why we ask -->
    <div style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.06);border-radius:10px;padding:1rem">
      <div style="font-size:0.65rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:rgba(255,255,255,0.28);margin-bottom:0.6rem">Why we ask</div>
      <div style="display:flex;flex-direction:column;gap:0.5rem">
        <div style="display:flex;gap:0.6rem"><span style="color:#3ab86a;font-size:0.8rem;flex-shrink:0">✓</span><span style="font-size:0.75rem;color:rgba(255,255,255,0.42);line-height:1.5">Name helps us personalise your loyalty card and rewards</span></div>
        <div style="display:flex;gap:0.6rem"><span style="color:#3ab86a;font-size:0.8rem;flex-shrink:0">✓</span><span style="font-size:0.75rem;color:rgba(255,255,255,0.42);line-height:1.5">Email lets us send you campaign offers and points updates</span></div>
        <div style="display:flex;gap:0.6rem"><span style="color:#3ab86a;font-size:0.8rem;flex-shrink:0">✓</span><span style="font-size:0.75rem;color:rgba(255,255,255,0.42);line-height:1.5">Birthday month unlocks a free birthday reward every year</span></div>
      </div>
    </div>

    <button class="btn btn-red" onclick="saveProfile()">Continue →</button>
    <button class="btn btn-ghost" onclick="goTo('s3')">Skip for now →</button>
    <div class="pdpa"><span>🔒</span><span>All fields optional · PDPA protected · Never sold · Delete anytime in Settings</span></div>
  </div>
</div>

<!-- S3: CONSENT -->
<div class="screen" id="s3">
  <div class="pad gap" style="background:#060C12;min-height:100vh">
    <button class="back-btn" onclick="goTo('s2c')">← Back</button>
    <div>
      <div class="eyebrow" style="margin-bottom:0.5rem">Step 3 of 3</div>
      <div class="headline" style="font-size:2.2rem">What we'd<br>like to share.</div>
      <p class="sub" style="margin-top:0.5rem">Choose what you're comfortable with. Change anytime in settings.</p>
    </div>
    <div style="display:flex;flex-direction:column;gap:0.65rem">
      <div class="consent-item selected">
        <div class="ccheck"><div class="ccheck-dot"></div></div>
        <div><div class="ctitle">Loyalty membership <span style="font-size:0.58rem;color:rgba(255,255,255,0.3);font-weight:400">(required)</span></div><div class="cdesc">Track visits and points at this merchant.</div></div>
      </div>
      <div class="consent-item" onclick="tc(this)">
        <div class="ccheck"><div class="ccheck-dot"></div></div>
        <div><div class="ctitle">Personalised offers</div><div class="cdesc">Campaigns based on your visit history.</div></div>
      </div>
      <div class="consent-item" onclick="tc(this)">
        <div class="ccheck"><div class="ccheck-dot"></div></div>
        <div><div class="ctitle">District rewards</div><div class="cdesc">Earn points across all CBOXX merchants in this mall.</div></div>
      </div>
    </div>
    <div class="pdpa"><span>🔒</span><span>PDPA compliant · CBOXX Pte. Ltd. (UEN: 202613969N) · Data never sold</span></div>
    <button class="btn btn-red" onclick="goTo('s4');vibe([40,30,60])">Confirm & Join →</button>
  </div>
</div>

<!-- S4: ENROLLED -->
<div class="screen" id="s4">
  <div class="pad gap" style="background:#000;align-items:center;text-align:center;min-height:100vh;justify-content:center">
    <div class="enrolled-tick">✓</div>
    <div style="animation:fadeUp 0.5s ease 0.3s both">
      <div style="font-family:'Barlow Condensed',sans-serif;font-size:3rem;font-weight:900;text-transform:uppercase;color:var(--off);letter-spacing:0.02em">You're in!</div>
      <div style="font-size:0.88rem;color:rgba(255,255,255,0.4);margin-top:0.25rem" id="enrolledSubText">Welcome to <span id="eName">Demo Store</span> loyalty</div>
    </div>
    <div class="member-card" style="width:100%;animation:fadeUp 0.5s ease 0.5s both">
      <div class="mc-top">
        <div><div class="mc-ml" id="eMall">Tampines Mall</div><div class="mc-mn" id="eMerchant">Demo Store</div></div>
        <span class="pill-red">🥉 Bronze</span>
      </div>
      <div class="divider" style="margin-bottom:0.85rem"></div>
      <div style="font-size:0.55rem;color:rgba(255,255,255,0.25);text-transform:uppercase;letter-spacing:0.1em;margin-bottom:0.15rem">Points earned today</div>
      <div class="mc-pts" id="ePts">0</div>
      <div class="mc-pts-sub">50 pts · First visit bonus · Member: +65 <span id="ePhone">81234567</span></div>
      <div class="prog-row"><span>Progress to Silver</span><span>50 / 500 pts</span></div>
      <div class="prog-track"><div class="prog-fill" id="eFill"></div></div>
    </div>
    <div class="rp-grid" style="width:100%;animation:fadeUp 0.5s ease 0.6s both">
      <div class="rp"><span class="rp-icon">🍜</span><span class="rp-label">Free item at 200 pts</span></div>
      <div class="rp"><span class="rp-icon">🥢</span><span class="rp-label">10% off at 500 pts</span></div>
      <div class="rp"><span class="rp-icon">👑</span><span class="rp-label">VIP at Gold</span></div>
    </div>
    <button onclick="goTo('s_home')" style="width:100%;padding:0.9rem;background:rgba(139,0,21,0.1);border:1px solid rgba(139,0,21,0.3);color:#ff8c8c;border-radius:10px;font-family:'Inter',sans-serif;font-size:0.88rem;font-weight:600;cursor:pointer;animation:fadeUp 0.5s ease 0.7s both">View my membership →</button>
    <button class="btn btn-ghost" onclick="goTo('s1')" style="animation:fadeUp 0.5s ease 0.8s both">Done · Close</button>
  </div>
</div>

<!-- HOME -->
<div class="screen" id="s_home">
  <div style="background:#000;padding:1.5rem 1.5rem 1rem;border-bottom:1px solid rgba(255,255,255,0.06)">
    <div style="display:flex;align-items:center;justify-content:space-between">
      <div>
        <div style="font-family:'Barlow Condensed',sans-serif;font-size:1.3rem;font-weight:900;color:var(--off);text-transform:uppercase">My Membership</div>
        <div style="font-size:0.68rem;color:rgba(255,255,255,0.3);margin-top:0.15rem" id="homeSub">Tampines Mall · Demo Store</div>
      </div>
      <span class="pill-red">🥉 Bronze</span>
    </div>
  </div>
  <div style="padding:1.25rem 1.5rem;display:flex;flex-direction:column;gap:1.1rem;overflow-y:auto">

    <!-- Member ID chip -->
    <div style="display:flex;align-items:center;gap:0.65rem;padding:0.7rem 1rem;background:rgba(29,78,216,0.08);border:1px solid rgba(29,78,216,0.2);border-radius:8px">
      <span style="font-size:1rem">📱</span>
      <div style="flex:1">
        <div style="font-size:0.72rem;font-weight:600;color:#60a5fa">CBOXX District Member</div>
        <div style="font-size:0.65rem;color:rgba(255,255,255,0.3);margin-top:0.1rem">+65 <span id="homePhone">81234567</span> · Tampines Mall · Active</div>
      </div>
      <span style="font-size:0.6rem;font-weight:700;padding:0.2rem 0.55rem;border-radius:100px;background:rgba(58,184,106,0.15);border:1px solid rgba(58,184,106,0.3);color:#3ab86a">Live</span>
    </div>

    <!-- District points hero -->
    <div class="pts-hero">
      <div style="font-size:0.6rem;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;color:rgba(255,255,255,0.3);margin-bottom:0.5rem">District Points · East Area</div>
      <div style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:1rem">
        <div>
          <div class="pts-big" id="distPts">340</div>
          <div style="font-size:0.68rem;color:rgba(255,255,255,0.3);margin-top:0.15rem">across all shops</div>
        </div>
        <div style="text-align:right">
          <div style="font-family:'Barlow Condensed',sans-serif;font-size:1.4rem;font-weight:900;color:var(--off)">3</div>
          <div style="font-size:0.62rem;color:rgba(255,255,255,0.3)">shops visited</div>
        </div>
      </div>
      <div class="divider" style="margin-bottom:0.85rem"></div>
      <div class="prog-row"><span>Gold tier at 1,000 pts</span><span>340 / 1,000</span></div>
      <div class="prog-track"><div class="prog-fill" style="width:34%"></div></div>
      <div style="display:flex;gap:0.5rem;margin-top:0.85rem">
        <div class="tb tb-bronze">🥉 Bronze<br><span style="font-size:0.5rem;opacity:0.7">0 pts</span></div>
        <div class="tb" style="background:rgba(201,150,58,0.2);border:1px solid rgba(201,150,58,0.4);color:var(--yellow);flex:1;padding:0.45rem 0.3rem;border-radius:6px;text-align:center;font-size:0.6rem;font-weight:700">🥈 Silver<br><span style="font-size:0.5rem;opacity:0.7">Current</span></div>
        <div class="tb tb-gold">🥇 Gold<br><span style="font-size:0.5rem;opacity:0.7">1,000 pts</span></div>
      </div>
    </div>

    <!-- District Loyalty Network -->
    <div>
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.75rem">
        <div class="eyebrow">My District · East Area</div>
        <span style="font-size:0.62rem;color:rgba(255,255,255,0.25)">Phase 1 Pilot</span>
      </div>

      <!-- East Area accordion -->
      <div class="area-group">

        <!-- EAST AREA header -->
        <div class="area-header" onclick="toggleArea('east')">
          <div style="display:flex;align-items:center;gap:0.75rem">
            <div style="width:36px;height:36px;background:rgba(139,0,21,0.15);border:1px solid rgba(139,0,21,0.3);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:1rem;flex-shrink:0">📍</div>
            <div>
              <div style="font-size:0.88rem;font-weight:700;color:var(--off)">East Area</div>
              <div style="font-size:0.62rem;color:rgba(255,255,255,0.3)">Phase 1 Pilot · 8 malls · 1,260+ merchants</div>
            </div>
          </div>
          <div style="display:flex;align-items:center;gap:0.5rem">
            <span style="font-family:'Barlow Condensed',sans-serif;font-size:1rem;font-weight:900;color:var(--yellow)">340 pts</span>
            <span id="east-arrow" style="font-size:0.72rem;color:rgba(255,255,255,0.25)">▸</span>
          </div>
        </div>

        <!-- EAST AREA content -->
        <div class="area-content" id="east-content">

          <!-- ── TAMPINES DISTRICT ── -->
          <div class="district-group">
            <div class="district-header" onclick="toggleDistrict('tampines')">
              <div style="font-size:0.78rem;font-weight:700;color:var(--off)">Tampines</div>
              <div style="display:flex;align-items:center;gap:0.5rem">
                <span style="font-size:0.62rem;color:rgba(255,255,255,0.3)">3 malls</span>
                <span id="tampines-arrow" style="font-size:0.65rem;color:rgba(255,255,255,0.2)">▸</span>
              </div>
            </div>
            <div class="district-content" id="tampines-content">

              <!-- Tampines Mall -->
              <div class="mall-item" onclick="toggleMall('tm')">
                <div class="mall-item-header">
                  <div style="display:flex;align-items:center;gap:0.6rem">
                    <span style="font-size:0.88rem">🏬</span>
