    <div style="width:72px;height:72px;background:rgba(201,150,58,0.15);border:2px solid rgba(201,150,58,0.4);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:1.8rem;animation:tickPop 0.5s cubic-bezier(0.175,0.885,0.32,1.275) both">👋</div>
    <div style="text-align:center;animation:fadeUp 0.5s ease 0.3s both">
      <div style="font-family:'Barlow Condensed',sans-serif;font-size:3rem;font-weight:900;text-transform:uppercase;color:var(--off);line-height:1;letter-spacing:0.02em">Welcome back!</div>
      <div style="font-size:0.85rem;color:rgba(255,255,255,0.4);margin-top:0.3rem">+65 <span id="retPhoneShow">81234567</span> · Visit #5 this month</div>
    </div>
    <div class="ret-pts-box" style="width:100%;animation:fadeUp 0.5s ease 0.4s both">
      <div><div style="font-size:0.6rem;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;color:rgba(255,255,255,0.3);margin-bottom:0.2rem">Points earned today</div><div class="ret-big">+60</div></div>
      <div style="text-align:right"><div style="font-size:0.6rem;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;color:rgba(255,255,255,0.3);margin-bottom:0.2rem">Total points</div><div class="ret-big">340</div></div>
    </div>
    <div class="member-card" style="width:100%;animation:fadeUp 0.5s ease 0.5s both">
      <div class="mc-top">
        <div><div class="mc-ml">Tampines Mall</div><div class="mc-mn" id="retMName">Demo Store</div></div>
        <span class="pill-amber">🥈 Silver</span>
      </div>
      <div class="divider" style="margin-bottom:0.75rem"></div>
      <div style="display:flex;gap:0.5rem;margin-bottom:1rem">
        <div class="sk" style="background:rgba(139,0,21,0.15);border:1px solid rgba(139,0,21,0.25)"><div class="sk-num" style="color:var(--off)">5</div><div class="sk-label" style="color:#ff8c8c">visits</div></div>
        <div class="sk" style="background:rgba(22,92,50,0.15);border:1px solid rgba(22,92,50,0.25)"><div class="sk-num" style="color:#3ab86a">3🔥</div><div class="sk-label" style="color:#3ab86a">streak</div></div>
        <div class="sk" style="background:rgba(201,150,58,0.12);border:1px solid rgba(201,150,58,0.2)"><div class="sk-num" style="color:var(--yellow)">340</div><div class="sk-label" style="color:var(--yellow)">pts</div></div>
      </div>
      <div class="prog-row"><span>Progress to Gold</span><span>340 / 1,000 pts</span></div>
      <div class="prog-track"><div class="prog-fill" style="width:34%"></div></div>
    </div>
    <div style="width:100%;background:rgba(139,0,21,0.08);border:1px solid rgba(139,0,21,0.2);border-radius:10px;padding:1rem;display:flex;gap:0.85rem;align-items:center;animation:fadeUp 0.5s ease 0.6s both">
      <span style="font-size:1.3rem;flex-shrink:0">🎁</span>
      <div><div style="font-size:0.82rem;font-weight:700;color:var(--off);margin-bottom:0.15rem">Weekend Double Points</div><div style="font-size:0.68rem;color:rgba(255,255,255,0.38);line-height:1.45">Active now · Earn 2x points this weekend · Ends Sunday</div></div>
    </div>
    <div style="width:100%;display:grid;grid-template-columns:1fr 1fr;gap:0.65rem;animation:fadeUp 0.5s ease 0.7s both">
      <button onclick="tab('s_rewards',null);goTo('s_rewards')" style="padding:0.85rem;background:var(--card);border:1px solid var(--border);border-radius:10px;color:rgba(255,255,255,0.65);font-family:'Inter',sans-serif;font-size:0.8rem;font-weight:600;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:0.4rem">🎁 My Rewards</button>
      <button onclick="goTo('s_home')" style="padding:0.85rem;background:var(--card);border:1px solid var(--border);border-radius:10px;color:rgba(255,255,255,0.65);font-family:'Inter',sans-serif;font-size:0.8rem;font-weight:600;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:0.4rem">🏠 My Profile</button>
    </div>
    <button class="btn btn-ghost" onclick="goTo('s1')" style="width:100%;animation:fadeUp 0.5s ease 0.8s both">Done · Close</button>
  </div>
</div>


<!-- POST-TAP SURVEY -->
<div class="screen" id="s_survey">
  <div class="pad gap" style="background:#060C12;min-height:100vh">

    <!-- Progress dots -->
    <div class="survey-progress">
      <div class="sp-dot done" id="sp1"></div>
      <div class="sp-dot done" id="sp2"></div>
      <div class="sp-dot" id="sp3"></div>
    </div>

    <!-- Step 1: Star rating -->
    <div class="survey-step active" id="sv1">
      <div style="font-family:'Barlow Condensed',sans-serif;font-size:2rem;font-weight:900;text-transform:uppercase;color:var(--off);line-height:1;margin-bottom:0.5rem">Rate your<br>experience.</div>
      <p style="font-size:0.85rem;color:rgba(255,255,255,0.4);line-height:1.6;margin-bottom:0.5rem">How was your visit to <span id="surveyShopName">this shop</span> today?</p>

      <div class="star-row" id="starRow">
        <button class="star-btn" onclick="rateStar(1)" id="star1">★</button>
        <button class="star-btn" onclick="rateStar(2)" id="star2">★</button>
        <button class="star-btn" onclick="rateStar(3)" id="star3">★</button>
        <button class="star-btn" onclick="rateStar(4)" id="star4">★</button>
        <button class="star-btn" onclick="rateStar(5)" id="star5">★</button>
      </div>

      <div style="text-align:center;font-size:0.75rem;color:rgba(255,255,255,0.25);margin-bottom:1.5rem" id="starLabel">Tap to rate</div>

      <button class="btn btn-red" id="sv1Btn" onclick="surveyNext(1)" disabled>Next →</button>
      <button class="btn btn-ghost" style="margin-top:0.5rem" onclick="skipSurvey()">Skip for now</button>
    </div>

    <!-- Step 2: Quick tags -->
    <div class="survey-step" id="sv2">
      <div style="font-family:'Barlow Condensed',sans-serif;font-size:2rem;font-weight:900;text-transform:uppercase;color:var(--off);line-height:1;margin-bottom:0.5rem">What stood<br>out?</div>
      <p style="font-size:0.85rem;color:rgba(255,255,255,0.4);line-height:1.6;margin-bottom:1rem">Select all that apply.</p>

      <div class="survey-opts" id="tagGrid">
        <button class="survey-opt" onclick="pickTag(this)">⚡ Fast service</button>
        <button class="survey-opt" onclick="pickTag(this)">😊 Friendly staff</button>
        <button class="survey-opt" onclick="pickTag(this)">🍽️ Great food/product</button>
        <button class="survey-opt" onclick="pickTag(this)">💰 Good value</button>
        <button class="survey-opt" onclick="pickTag(this)">🏪 Clean environment</button>
        <button class="survey-opt" onclick="pickTag(this)">⏳ Had to wait</button>
        <button class="survey-opt survey-opt full-width" onclick="pickTag(this)">😞 Not what I expected</button>
      </div>

      <button class="btn btn-red" style="margin-top:0.75rem" onclick="surveyNext(2)">Next →</button>
      <button class="btn btn-ghost" style="margin-top:0.5rem" onclick="skipSurvey()">Skip</button>
    </div>

    <!-- Step 3: Open comment (optional) -->
    <div class="survey-step" id="sv3">
      <div style="font-family:'Barlow Condensed',sans-serif;font-size:2rem;font-weight:900;text-transform:uppercase;color:var(--off);line-height:1;margin-bottom:0.5rem">Anything<br>else?</div>
      <p style="font-size:0.85rem;color:rgba(255,255,255,0.4);line-height:1.6;margin-bottom:1rem">Optional — leave a note for the merchant.</p>

      <textarea class="survey-msg" id="surveyComment" rows="4" placeholder="Tell us more about your visit today..."></textarea>

      <div style="margin-top:0.35rem;font-size:0.62rem;color:rgba(255,255,255,0.2)">This goes directly to the merchant. Optional.</div>

      <button class="btn btn-red" style="margin-top:1rem" onclick="submitSurvey()">Submit feedback →</button>
      <button class="btn btn-ghost" style="margin-top:0.5rem" onclick="skipSurvey()">Skip</button>
    </div>

    <!-- Thank you -->
    <div class="survey-step" id="sv4">
      <div class="survey-thanks">
        <div class="survey-thanks-icon">🙏</div>
        <div style="font-family:'Barlow Condensed',sans-serif;font-size:2.2rem;font-weight:900;text-transform:uppercase;color:var(--off)">Thank you!</div>
        <p style="font-size:0.88rem;color:rgba(255,255,255,0.4);line-height:1.65;max-width:280px">Your feedback helps <span id="surveyShopName2">this shop</span> improve. You've earned a bonus <strong style="color:var(--yellow)">+10 pts</strong> for sharing.</p>

        <!-- Bonus points card -->
        <div style="width:100%;background:rgba(201,150,58,0.08);border:1px solid rgba(201,150,58,0.2);border-radius:12px;padding:1rem;display:flex;align-items:center;justify-content:space-between">
          <div>
            <div style="font-size:0.62rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:rgba(255,255,255,0.3);margin-bottom:0.2rem">Survey bonus</div>
            <div style="font-family:'Barlow Condensed',sans-serif;font-size:2rem;font-weight:900;color:var(--yellow)">+10 pts</div>
          </div>
          <div style="font-size:2rem">⭐</div>
        </div>

        <button class="btn btn-red" style="width:100%" onclick="goTo('s_home')">View my membership →</button>
        <button class="btn btn-ghost" style="width:100%" onclick="goTo('s1')">Done · Close</button>
      </div>
    </div>

  </div>
</div>
</div>
<script>
var params=new URLSearchParams(window.location.search);
var mall=params.get('mall')||'Tampines Mall';
var mName=params.get('name')||'Demo Store';
var phoneNum='';

// Set names
['mName','lpName','eName','eMerchant','retMName','sMerchant'].forEach(function(id){
  var el=document.getElementById(id);
  if(el) el.textContent=id==='mName'?mName+'.':mName;
});
['mallTag','eMall'].forEach(function(id){var el=document.getElementById(id);if(el)el.textContent=mall;});
document.getElementById('homeSub').textContent='East Area · District Member';
document.getElementById('settingsSub').textContent=mName+' membership';

function goTo(id){
  document.querySelectorAll('.screen').forEach(function(s){s.classList.remove('active');});
  var el=document.getElementById(id);
  if(el)el.classList.add('active');
  window.scrollTo(0,0);
  if(id==='s4')startEnrolled();
}

function tab(id,btn){
  goTo(id);
  if(btn){
    document.querySelectorAll('.bn-item').forEach(function(b){b.classList.remove('active');});
    btn.classList.add('active');
  }
}

function vibe(p){if(navigator.vibrate)navigator.vibrate(p);}
function tc(el){el.classList.toggle('selected');}

function onPhone(input){
  var v=input.value.replace(/\D/g,'');input.value=v;
  var btn=document.getElementById('phoneBtn');
  var hint=document.getElementById('phoneHint');
  if(v.length===8&&(v[0]==='8'||v[0]==='9'||v[0]==='6')){
    input.classList.add('valid');input.classList.remove('error');
    btn.disabled=false;hint.textContent='Looks good!';hint.classList.remove('err');
  }else if(v.length===8){
    input.classList.add('error');input.classList.remove('valid');
    btn.disabled=true;hint.textContent='Enter a valid SG mobile number';hint.classList.add('err');
  }else{
    input.classList.remove('valid','error');btn.disabled=true;
    hint.textContent='Enter your 8-digit Singapore mobile number';hint.classList.remove('err');
  }
}

function submitPhone(){
  var v=document.getElementById('phoneInput').value.replace(/\D/g,'');
  if(v.length!==8)return;
  phoneNum=v;
  document.getElementById('phoneDisplay').textContent='+65 '+v.slice(0,4)+' '+v.slice(4);
  goTo('s2b');
}

function onOtp(input){
  var v=input.value.replace(/\D/g,'');input.value=v;
  document.getElementById('otpBtn').disabled=v.length<6;
}

function submitOtp(){
  var v=document.getElementById('otpInput').value;
  if(v==='654321'){
    document.getElementById('retPhoneShow').textContent=phoneNum.slice(0,4)+' '+phoneNum.slice(4);
    goTo('s_returning');
  }else{goTo('s2c');}
}

function resend(){
  var h=document.getElementById('otpHint');
  h.textContent='Code resent!';h.style.color='#3ab86a';
  setTimeout(function(){h.textContent='Enter the 6-digit code';h.style.color='';},3000);
}

function startEnrolled(){

  // Update settings display after profile save
  var sn = document.getElementById('sName'); if(sn) sn.textContent = profileData.name || 'Not set';
  var se = document.getElementById('sEmail'); if(se) se.textContent = profileData.email || 'Not set';
  var sb = document.getElementById('sBday'); if(sb) sb.textContent = profileData.bday || 'Not set';

  ['ePhone','homePhone','sPhone'].forEach(function(id){var el=document.getElementById(id);if(el)el.textContent=phoneNum||'81234567';});
  var pts=0,t=setInterval(function(){pts+=2;var el=document.getElementById('ePts');if(el)el.textContent=pts;if(pts>=50)clearInterval(t);},28);
  setTimeout(function(){var f=document.getElementById('eFill');if(f)f.style.width='10%';},700);
}

function onRetPhone(input){
  var v=input.value.replace(/\D/g,'');input.value=v;
  document.getElementById('retBtn').disabled=v.length!==8;
}

function submitRet(){
  var v=document.getElementById('retInput').value;
  if(v.length!==8)return;
  document.getElementById('retPhoneShow').textContent=v.slice(0,4)+' '+v.slice(4);
  goTo('s_returning');
}



// ── SURVEY ──
var surveyRating = 0;
var surveyTags = [];
var currentSurveyStep = 1;

function rateStar(n) {
  surveyRating = n;
  for (var i = 1; i <= 5; i++) {
    var s = document.getElementById('star' + i);
    if (s) s.classList.toggle('lit', i <= n);
  }
  var labels = ['', 'Poor', 'Fair', 'Good', 'Great', 'Excellent!'];
  var lbl = document.getElementById('starLabel');
  if (lbl) lbl.textContent = labels[n] + ' · ' + n + '/5';
  var btn = document.getElementById('sv1Btn');
  if (btn) btn.disabled = false;
  if (navigator.vibrate) navigator.vibrate(20);
}

function pickTag(el) {
  el.classList.toggle('picked');
  if (navigator.vibrate) navigator.vibrate(15);
}

function surveyNext(step) {
  document.getElementById('sv' + step).classList.remove('active');
  document.getElementById('sv' + (step + 1)).classList.add('active');
  document.getElementById('sp' + (step < 3 ? step + 1 : 3)).classList.add('done');
  currentSurveyStep = step + 1;
  if (navigator.vibrate) navigator.vibrate(20);
}

function submitSurvey() {
  // Collect all data
  var tags = [];
  document.querySelectorAll('.survey-opt.picked').forEach(function(el) { tags.push(el.textContent.trim()); });
  var comment = document.getElementById('surveyComment') ? document.getElementById('surveyComment').value : '';
  
  // In real build: POST to Dylan's backend
  // { rating: surveyRating, tags: tags, comment: comment, merchant: mName, phone: phoneNum, timestamp: Date.now() }
  console.log('Survey submitted:', { rating: surveyRating, tags: tags, comment: comment });
  
  // Show thank you
  document.getElementById('sv3').classList.remove('active');
  document.getElementById('sv4').classList.add('active');
  document.querySelectorAll('.sp-dot').forEach(function(d) { d.classList.add('done'); });
  if (navigator.vibrate) navigator.vibrate([40, 30, 60]);
}

function skipSurvey() {
  goTo('s_home');
}

// Set shop name in survey
function setSurveyShop(name) {
  ['surveyShopName', 'surveyShopName2'].forEach(function(id) {
    var el = document.getElementById(id);
    if (el) el.textContent = name;
  });
}


// Profile data
var profileData = { name: '', email: '', bday: '' };

function saveProfile() {
  profileData.name = document.getElementById('profileName').value.trim();
  profileData.email = document.getElementById('profileEmail').value.trim();
  profileData.bday = document.getElementById('profileBday').value;
  // Update display name on enrolled screen if name provided
  if (profileData.name) {
    var eName = document.getElementById('eName');
    if (eName) eName.textContent = profileData.name + ' · ' + (document.getElementById('eMerchant') ? document.getElementById('eMerchant').textContent : mName);
  }
  // In real build: POST { phone: phoneNum, name, email, bday } to backend
  console.log('Profile saved:', { phone: phoneNum, ...profileData });
  goTo('s3');
}


function switchDistrict(id, btn) {
  document.querySelectorAll('.dtab').forEach(function(t){ t.classList.remove('active'); });
  document.querySelectorAll('.district-panel').forEach(function(p){ p.classList.remove('active'); });
  btn.classList.add('active');
  var panel = document.getElementById('dp-' + id);
  if (panel) panel.classList.add('active');
}


function toggleArea(id) {
  var content = document.getElementById(id + '-content');
  var arrow = document.getElementById(id + '-arrow');
  if (!content) return;
  var open = content.classList.contains('open');
  content.classList.toggle('open', !open);
  if (arrow) arrow.textContent = open ? '▸' : '▾';
  if (!open && navigator.vibrate) navigator.vibrate(15);
}

function toggleDistrict(id) {
  var content = document.getElementById(id + '-content');
  var arrow = document.getElementById(id + '-arrow');
  if (!content) return;
  var open = content.classList.contains('open');
  // Close others
  document.querySelectorAll('.district-content').forEach(function(d){ d.classList.remove('open'); });
  document.querySelectorAll('[id$="-arrow"]').forEach(function(a){
    if(a.id.split('-').length === 2 && a.id !== 'east-arrow') a.textContent = '▸';
  });
  if (!open) {
    content.classList.add('open');
    if (arrow) arrow.textContent = '▾';
    if (navigator.vibrate) navigator.vibrate(15);
  }
}

function toggleMall(id) {
  var shops = document.getElementById(id + '-shops');
  var arrow = document.getElementById(id + '-arrow');
  if (!shops) return;
  var isOpen = shops.classList.contains('open');
  // Close all malls first
  document.querySelectorAll('.mall-shops').forEach(function(s){ s.classList.remove('open'); });
  document.querySelectorAll('[id$="-arrow"]').forEach(function(a){ if(a.id.split('-').length===2) a.textContent='▸'; });
  if (!isOpen) {
    shops.classList.add('open');
    if (arrow) arrow.textContent = '▾';
    if (navigator.vibrate) navigator.vibrate(15);
  }
}

function toggleShop(id) {
  var detail = document.getElementById(id);
  var arrow = document.getElementById(id + 'arrow');
  var isOpen = detail.classList.contains('open');
  // Close all first
  document.querySelectorAll('.shop-detail').forEach(function(d){ d.classList.remove('open'); });
  document.querySelectorAll('[id$="arrow"]').forEach(function(a){ a.textContent = '▸'; });
  // Toggle clicked
  if (!isOpen) {
    detail.classList.add('open');
    if (arrow) arrow.textContent = '▾';
    if (navigator.vibrate) navigator.vibrate(15);
  }
}

// Auto-open East Area
setTimeout(function(){
  var ec = document.getElementById('east-content');
  var ea = document.getElementById('east-arrow');
  if(ec){ ec.classList.add('open'); if(ea) ea.textContent='▾'; }
}, 600);

// Live stats
setTimeout(function(){
  var m=0,t=0;
  var mi=setInterval(function(){m++;document.getElementById('lsM').textContent=m;if(m>=34)clearInterval(mi);},40);
  var ti=setInterval(function(){t+=52;document.getElementById('lsT').textContent=t;if(t>=1860)clearInterval(ti);},18);
  var p=0,pi=setInterval(function(){p++;var el=document.getElementById('lpPts');if(el)el.textContent=p;if(p>=50)clearInterval(pi);},30);
},500);
</script>
</body>
</html>
